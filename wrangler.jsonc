{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "micromacrotrackerwebsite",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    { "pattern": "micromacronutrilabs.com/*", "zone_name": "micromacronutrilabs.com" },
    { "pattern": "www.micromacronutrilabs.com/*", "zone_name": "micromacronutrilabs.com" }
  ]
}
